{
  "name": "openapi-templates",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Système de templating YAML pour OpenAPI (exposed | called | events)",
  "scripts": {
    "build": "node tools/build.mjs",
    "build:one": "node tools/build.mjs --project",
    "import": "node tools/import.mjs",
    "lint": "redocly lint build/*.openapi.yaml"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@redocly/cli": "^1.25.0"
  }
}
